{
  "expo": {
    "name": "Examen",
    "slug": "examen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "Examen - Exame de Consciência",
      "shortName": "Examen",
      "description": "Exame de Consciência, Catecismo, Compêndio e Estudos Bíblicos da Igreja Católica.",
      "themeColor": "#0D0D0D",
      "backgroundColor": "#0D0D0D",
      "lang": "pt-BR"
    },
    "plugins": [
      "expo-sqlite"
    ]
  }
}
